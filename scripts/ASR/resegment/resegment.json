{
  "script": "ASR/resegment/resegment.py",
  "description": "JSON szegmensek újraformázása - ASR script által létrehozott JSON fájlok biztonsági mentése és újraformázása különböző paraméterekkel.",
  "required": [
    {
      "name": "project_name",
      "flags": [
        "-p",
        "--project-name"
      ],
      "type": "option",
      "default": null
    }
  ],
  "optional": [
    {
      "name": "max_pause",
      "flags": [
        "--max-pause"
      ],
      "type": "option",
      "default": 0.3
    },
    {
      "name": "timestamp_padding",
      "flags": [
        "--timestamp-padding"
      ],
      "type": "option",
      "default": 0.1
    },
    {
      "name": "max_segment_duration",
      "flags": [
        "--max-segment-duration"
      ],
      "type": "option",
      "default": 11.5
    },
    {
      "name": "enforce_single_speaker",
      "flags": [
        "--enforce-single-speaker"
      ],
      "type": "flag",
      "default": false
    },
    {
      "name": "backup_disable",
      "flags": [
        "--backup_disable"
      ],
      "type": "flag",
      "default": false
    },
    {
      "name": "skip_energy_refine",
      "flags": [
        "--skip-energy-refine"
      ],
      "type": "flag",
      "default": false
    },
    {
      "name": "word_by_word_segments",
      "flags": [
        "--word-by-word-segments"
      ],
      "type": "flag",
      "default": false
    },
    {
      "name": "detect_speaker_changes",
      "flags": [
        "--detect-speaker-changes"
      ],
      "type": "flag",
      "default": false
    },
    {
      "name": "hf_token",
      "flags": [
        "--hf-token"
      ],
      "type": "option",
      "default": null
    },
    {
      "name": "speaker_change_preset",
      "flags": [
        "--speaker-change-preset"
      ],
      "type": "option",
      "default": "balanced"
    },
    {
      "name": "speaker_change_device",
      "flags": [
        "--speaker-change-device"
      ],
      "type": "option",
      "default": "cuda"
    },
    {
      "name": "speaker_change_max_speakers",
      "flags": [
        "--speaker-change-max-speakers"
      ],
      "type": "option",
      "default": 50
    },
    {
      "name": "speaker_change_min_region",
      "flags": [
        "--speaker-change-min-region"
      ],
      "type": "option",
      "default": null
    },
    {
      "name": "speaker_change_no_refine",
      "flags": [
        "--speaker-change-no-refine"
      ],
      "type": "flag",
      "default": false
    },
    {
      "name": "debug",
      "flags": [
        "--debug"
      ],
      "type": "flag",
      "default": false
    }
  ],
  "environment": "sync"
}
